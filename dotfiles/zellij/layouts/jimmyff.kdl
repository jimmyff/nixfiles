// Default layout — the single source of truth.
// - Fallback when a session starts without a project .zellij.kdl
//   (default_layout "jimmyff" in config.kdl).
// - `mux init` copies this file as the starting point for a project's .zellij.kdl.
// See docs/multiplexing.md.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="edit" {
        pane
    }
    tab name="git" {
        pane
    }
}
