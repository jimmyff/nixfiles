{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "attribution": {},
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:pub.dev)",
      "Edit(//tmp/**)",
      "Find(~/nixfiles/**)",
      "Read(~/nixfiles/**)",
      "Read(~/.pub-cache/**)",
      "Read(~/.cache/dart-pub/**)",
      "Bash(dart test:*)",
      "Bash(flutter test:*)",
      "Bash(timeout 10 flutter test:*)",
      "Bash(timeout 15 flutter test:*)",
      "Bash(timeout 20 flutter test:*)",
      "Bash(timeout 30 flutter test:*)",
      "Bash(timeout 60 flutter test:*)",
      "Bash(timeout 90 flutter test:*)",
      "Bash(timeout 120 flutter test:*)",
      "Bash(timeout 10 dart test:*)",
      "Bash(timeout 15 dart test:*)",
      "Bash(timeout 20 dart test:*)",
      "Bash(timeout 30 dart test:*)",
      "Bash(timeout 60 dart test:*)",
      "Bash(timeout 90 dart test:*)",
      "Bash(timeout 120 dart test:*)",
      "Bash(dart run build_runner build:*)",
      "Bash(dart pub get:*)",
      "Bash(flutter pub get:*)",
      "Bash(dart analyze:*)",
      "Bash(flutter analyze:*)",
      "Bash(grep:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git submodule:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "enabledMcpjsonServers": [
    "github"
  ],
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
